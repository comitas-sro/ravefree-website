{
  "name": "ravefree-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build --webpack && ./inline-css.mjs && next-export-optimize-images",
    "code-quality": "concurrently -m 1 'npm run lint' 'npm run build'",
    "dev": "next dev --webpack",
    "format": "prettier --write .",
    "lint": "concurrently -m 1 'npm run lint:eslint' 'npm run lint:typescript'",
    "lint:eslint": "eslint --concurrency auto",
    "lint:typescript": "next typegen && tsc",
    "start": "next start"
  },
  "dependencies": {
    "@next/mdx": "^16.2.9",
    "next": "^16.2.9",
    "next-export-optimize-images": "^4.7.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.19.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "beasties": "^0.4.2",
    "concurrently": "^10.0.3",
    "eslint": "^10",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-preset-env": "^11.2.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "wrangler": "^4.92.0"
  },
  "overrides": {
    "next-export-optimize-images": {
      "next": "^16"
    },
    "postcss": "^8.5.10",
    "wrangler": {
      "esbuild": "~0.28.1",
      "miniflare": {
        "ws": "^8.20.1"
      }
    }
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.11.1": true,
    "workerd@1.20260515.1": true
  }
}
